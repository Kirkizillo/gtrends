# Google Sheets Configuration
# ==========================

# ID del Google Sheet (extraer de la URL)
# Ejemplo: https://docs.google.com/spreadsheets/d/1ABC123xyz/edit
# El ID sería: 1ABC123xyz
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Ruta al archivo de credenciales de servicio (Service Account JSON)
# Por defecto busca 'credentials.json' en el directorio del proyecto
GOOGLE_CREDENTIALS_PATH=credentials.json

# Turso Database (SQLite cloud)
# ==============================
# Obtener en: https://turso.tech (cuenta gratuita)
# Crear DB: turso db create trends-monitor
# Obtener URL: turso db show trends-monitor --url
# Crear token: turso db tokens create trends-monitor
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your_auth_token_here
